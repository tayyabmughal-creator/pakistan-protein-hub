    "@tanstack/react-query": "^5.95.2",
    "axios": "^1.13.6",
    "expo": "~55.0.8",
    "expo-blur": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-device": "~55.0.10",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
