SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=shop.example.com,www.shop.example.com
CSRF_TRUSTED_ORIGINS=https://shop.example.com,https://www.shop.example.com
CORS_ALLOWED_ORIGINS=https://shop.example.com,https://www.shop.example.com
FRONTEND_URL=https://shop.example.com
BACKEND_PUBLIC_URL=https://shop.example.com
ADMIN_URL=secure-admin/

# Docker/VPS production path should use PostgreSQL via the `db` service hostname.
POSTGRES_DB=paknutrition
POSTGRES_USER=paknutrition
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=no-reply@shop.example.com
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=PakNutrition <no-reply@shop.example.com>
ORDER_NOTIFICATION_EMAIL_ENABLED=True
ORDER_NOTIFICATION_SMS_ENABLED=False
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

SAFEPAY_ENABLED=False
SAFEPAY_ENV=sandbox
SAFEPAY_API_KEY=
SAFEPAY_SHARED_SECRET=
SAFEPAY_SOURCE=paknutrition

EASYPAISA_ACCOUNT=03xxxxxxxxx
JAZZCASH_ACCOUNT=03xxxxxxxxx
BANK_ACCOUNT_TITLE=PakNutrition
BANK_ACCOUNT_NUMBER=0000000000000000
BANK_NAME=Bank Name
MANUAL_PAYMENT_NOTE=Complete the transfer first, then enter the transaction reference so PakNutrition can verify your payment quickly.

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
